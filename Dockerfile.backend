FROM python:3.13-slim

WORKDIR /app

# 安装依赖
COPY backend/requirements.txt* ./
RUN pip install --no-cache-dir fastapi uvicorn sqlalchemy pymysql pydantic pydantic-settings python-jose[cryptography] passlib[bcrypt] python-multipart 2>/dev/null || true

# 复制代码
COPY backend/ .

# 暴露端口
EXPOSE 8000

# 启动命令
CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
